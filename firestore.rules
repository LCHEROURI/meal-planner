rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }
    
    // USERS and their subcollections
    match /users/{userId} {
      allow read, update, create, delete: if isOwner(userId);
      
      // Meal Plans subcollection
      match /mealPlans/{planId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // PUBLIC SHARES
    match /sharedPlans/{shareId} {
      // Anyone can read an active share
      allow read: if resource.data.isPublic == true;
      // Only owner can create/update/delete
      allow create: if isOwner(request.resource.data.sharedBy);
      allow update: if isOwner(resource.data.sharedBy) && isOwner(request.resource.data.sharedBy);
      allow delete: if isOwner(resource.data.sharedBy);
    }
  }
}
